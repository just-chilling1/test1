NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App domain — where this software is hosted (auth redirects, password-reset emails).
# Local: http://localhost:3000  |  Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Software name — shown in auth UI, onboarding, training copy, browser title.
# Change to your product name (e.g. My SaaS App). Also update brand.config.ts colors/logo.
NEXT_PUBLIC_PRODUCT_NAME=NovaAI

# Local preview only — skip login + onboarding redirects
# DEV_BYPASS_AUTH=true

# Optional: signup webhook (Make.com, etc.)
WEBHOOK_SIGNUP_URL=

# Feature module env (only when core-workflow is enabled)
# RAPIDAPI_KEY=
# RAPIDAPI_HOST_CHATGPT=chatgpt-42.p.rapidapi.com
# RAPIDAPI_HOST_REDDIT=
# RAPIDAPI_HOST_YOUTUBE=
# SCRAPERAPI_KEY=

# article-images / image-forge
# RAPIDAPI_HOST_IMAGE=
# RAPIDAPI_IMAGE_PATH=/generate

# b2b-outreach — server-only admin key for lead allocation + offer seeding
# SUPABASE_SERVICE_ROLE_KEY=

# Script-only (apply-supabase-auth-setup.mjs)
# SUPABASE_ACCESS_TOKEN=
# PROJECT_REF=
